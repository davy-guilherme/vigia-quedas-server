<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <title>Cadastro - Vigia Quedas</title>
  <%- include('../parts/head') %>
  <style>

    body {

      min-height: 100vh;

      background:
        linear-gradient(
          135deg,
          #0d6efd,
          #0a58ca
        );

      display: flex;
      justify-content: center;
      align-items: center;

      padding: 20px;
      padding-top: 100px;
    }

    /* Navbar */

    .navbar {

      background: transparent !important;
      backdrop-filter: blur(6px);
    }

    .navbar-brand,
    .nav-link {

      color: white !important;
    }

    .nav-link {

      opacity: 0.85;
      transition: 0.2s;
    }

    .nav-link:hover {

      opacity: 1;
    }

    .navbar-toggler {

      border-color: rgba(255,255,255,0.25);
    }

    .navbar-toggler-icon {

      filter: brightness(100);
    }

    /* Container */

    .register-wrapper {

      width: 100%;
      max-width: 500px;
    }

    /* Marca */

    .brand {

      text-align: center;
      color: white;
      margin-bottom: 25px;
    }

    .brand-icon {

      font-size: 3.5rem;
    }

    .brand h1 {

      font-size: 2.2rem;
      font-weight: 700;
      margin-top: 10px;
      margin-bottom: 10px;
    }

    .brand p {

      color: rgba(255,255,255,0.85);
      margin: 0;
    }

    /* Card */

    .register-card {

      border: none;
      border-radius: 24px;
      overflow: hidden;
    }

    .card-body {

      padding: 40px;
    }

    .register-title {

      font-weight: 700;
      color: #212529;
    }

    /* Inputs */

    .form-control {

      border-radius: 12px;
      padding: 12px 14px;
      border: 1px solid #dee2e6;
    }

    .form-control:focus {

      box-shadow: 0 0 0 0.2rem rgba(13,110,253,0.15);
      border-color: #0d6efd;
    }

    .input-group-text {

      border-radius: 12px 0 0 12px;
      background: white;
    }

    /* Botões */

    .btn-primary,
    .btn-outline-secondary {

      border-radius: 12px;
      padding: 12px;
      font-weight: 600;
    }

    /* Rodapé */

    .footer-text {

      text-align: center;
      margin-top: 20px;
      color: rgba(255,255,255,0.8);
      font-size: 0.9rem;
    }

    #error,
    #success {

      min-height: 24px;
    }

  </style>

</head>
<body>

  <!-- Navbar -->
  <nav class="navbar navbar-expand-lg fixed-top">

    <div class="container">

      <a class="navbar-brand fw-bold" href="/">
        <i class="bi bi-shield-check"></i>
        Vigia Quedas
      </a>

      <button
        class="navbar-toggler"
        type="button"
        data-bs-toggle="collapse"
        data-bs-target="#menu"
      >
        <span class="navbar-toggler-icon"></span>
      </button>

      <div class="collapse navbar-collapse" id="menu">

        <ul class="navbar-nav ms-auto">

          <li class="nav-item">
            <a class="nav-link" href="/">
              Início
            </a>
          </li>

          <li class="nav-item">
            <a class="nav-link" href="/auth/login">
              Entrar
            </a>
          </li>

        </ul>

      </div>

    </div>

  </nav>

  <!-- Conteúdo -->
  <div class="register-wrapper">

    <!-- Marca -->
    <div class="brand">

      <div class="brand-icon">
        <i class="bi bi-shield-check"></i>
      </div>

      <h1>Vigia Quedas</h1>

      <p>
        Crie sua conta para começar o monitoramento
      </p>

    </div>

    <!-- Card -->
    <div class="card shadow-lg register-card">

      <div class="card-body">

        <h3 class="text-center mb-4 register-title">
          Criar Conta
        </h3>

        <form id="registerForm">

          <!-- Nome -->
          <div class="mb-3">

            <label for="nome" class="form-label">
              Nome Completo
            </label>

            <div class="input-group">

              <span class="input-group-text">
                <i class="bi bi-person"></i>
              </span>

              <input
                type="text"
                id="nome"
                class="form-control"
                placeholder="Digite seu nome"
                required
              >

            </div>

          </div>

          <!-- Email -->
          <div class="mb-3">

            <label for="email" class="form-label">
              E-mail
            </label>

            <div class="input-group">

              <span class="input-group-text">
                <i class="bi bi-envelope"></i>
              </span>

              <input
                type="email"
                id="email"
                class="form-control"
                placeholder="Digite seu e-mail"
                required
              >

            </div>

          </div>

          <!-- Senha -->
          <div class="mb-3">

            <label for="senha" class="form-label">
              Senha
            </label>

            <div class="input-group">

              <span class="input-group-text">
                <i class="bi bi-lock"></i>
              </span>

              <input
                type="password"
                id="senha"
                class="form-control"
                placeholder="Crie uma senha"
                required
              >

            </div>

          </div>

          <!-- Confirmar senha -->
          <div class="mb-3">

            <label for="confirmarSenha" class="form-label">
              Confirmar Senha
            </label>

            <div class="input-group">

              <span class="input-group-text">
                <i class="bi bi-shield-lock"></i>
              </span>

              <input
                type="password"
                id="confirmarSenha"
                class="form-control"
                placeholder="Repita sua senha"
                required
              >

            </div>

          </div>

          <!-- Botão -->
          <button
            class="btn btn-primary w-100 mt-3"
            type="submit"
          >
            Criar Conta
          </button>

          <!-- Link login -->
          <div class="text-center mt-4">

            <span class="text-muted">
              Já possui uma conta?
            </span>

            <a
              href="/auth/login"
              class="text-decoration-none fw-semibold"
            >
              Entrar
            </a>

          </div>

          <!-- Mensagens -->
          <div
            id="error"
            class="text-danger mt-3 text-center"
          ></div>

          <div
            id="success"
            class="text-success mt-2 text-center"
          ></div>

        </form>

      </div>

    </div>

    <!-- Rodapé -->
    <div class="footer-text">
      © 2026 Vigia Quedas
    </div>

  </div>

  <!-- Bootstrap -->
  <script src="../../bootstrap-5.3.7-dist/js/bootstrap.bundle.min.js"></script>

  <script>

    const form = document.getElementById("registerForm");

    const error =
      document.getElementById("error");

    const success =
      document.getElementById("success");

    form.addEventListener("submit", async (e) => {

      e.preventDefault();

      error.textContent = "";
      success.textContent = "";

      const nome =
        document.getElementById("nome").value;

      const email =
        document.getElementById("email").value;

      const senha =
        document.getElementById("senha").value;

      const confirmarSenha =
        document.getElementById("confirmarSenha").value;

      if (senha !== confirmarSenha) {

        error.textContent =
          "As senhas não coincidem.";

        return;
      }

      try {

        const resp = await fetch("/auth/register", {

          method: "POST",

          headers: {
            "Content-Type": "application/json"
          },

          body: JSON.stringify({
            nome,
            email,
            senha
          })

        });

        const data = await resp.json();

        if (!resp.ok) {

          error.textContent =
            data.erro || "Erro ao criar conta.";

          return;
        }

        success.textContent =
          "Conta criada com sucesso!";

        setTimeout(() => {

          window.location.href = "/login";

        }, 1500);

      } catch (err) {

        error.textContent =
          "Erro ao conectar com o servidor.";

      }

    });

  </script>

</body>
</html>