    <%- include('../parts/head') %>
    <style>

        body {

            background: #f4f7fb;
        }


        /* Cards */

        .device-card {

            border: none;
            border-radius: 24px;

            transition: 0.2s ease;
        }

        .device-card:hover {

            transform: translateY(-5px);

            box-shadow:
                0 10px 30px rgba(0,0,0,0.08);
        }

        .device-icon {

            width: 70px;
            height: 70px;

            border-radius: 20px;

            display: flex;
            align-items: center;
            justify-content: center;

            background:
                rgba(13,110,253,0.1);

            color: #0d6efd;

            font-size: 2rem;
        }

        .battery-bar {

            height: 10px;
            border-radius: 999px;

            overflow: hidden;

            background: #e9ecef;
        }

        .battery-level {

            height: 100%;
            border-radius: 999px;
        }

        .status-badge {

            font-size: 0.85rem;
            padding: 8px 12px;

            border-radius: 999px;
        }

    </style>

</head>
