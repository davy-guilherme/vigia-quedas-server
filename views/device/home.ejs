<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <title>Dispositivos - Vigia Quedas</title>
    <%- include('../parts/head') %>
    <style>

        body {

            background: #f4f7fb;
        }


        /* Cards */

        .device-card {

            border: none;
            border-radius: 24px;

            transition: 0.2s ease;
        }

        .device-card:hover {

            transform: translateY(-5px);

            box-shadow:
                0 10px 30px rgba(0,0,0,0.08);
        }

        .device-icon {

            width: 70px;
            height: 70px;

            border-radius: 20px;

            display: flex;
            align-items: center;
            justify-content: center;

            background:
                rgba(13,110,253,0.1);

            color: #0d6efd;

            font-size: 2rem;
        }

        .battery-bar {

            height: 10px;
            border-radius: 999px;

            overflow: hidden;

            background: #e9ecef;
        }

        .battery-level {

            height: 100%;
            border-radius: 999px;
        }

        .status-badge {

            font-size: 0.85rem;
            padding: 8px 12px;

            border-radius: 999px;
        }

    </style>

</head>
<body>

    <%- include('../parts/dash-template') %>

    <!-- Conteúdo -->
    <main class="main-content">

        <!-- Topbar -->
        <div class="topbar d-flex justify-content-between align-items-center flex-wrap gap-3">

            <div>

                <h2 class="fw-bold mb-1">
                    Dispositivos
                </h2>

                <p class="text-muted mb-0">
                    Gerencie os dispositivos vinculados à sua conta
                </p>

            </div>

            <button class="btn btn-primary">

                <i class="bi bi-plus-lg"></i>
                Novo Dispositivo

            </button>

        </div>

        <!-- Cards -->
        <div class="row g-4">

        <% if (devices && devices.length > 0) { %>
            <% devices.forEach(device => { %>
                
                <div class="col-lg-4 col-md-6 mb-4">
                    <div class="card device-card shadow-sm h-100">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-start mb-4">
                                <div class="device-icon">
                                    <i class="bi bi-cpu"></i>
                                </div>
                                
                                <span class="badge <%= device.status === 'online' ? 'bg-success' : 'bg-danger' %> status-badge" data-device-id="<%= device.id %>">
                                    <%= device.status === 'online' ? 'Online' : 'Offline' %>
                                </span>
                            </div>

                            <h4 class="fw-bold text-uppercase">
                                <%= device.serial_number %>
                            </h4>

                            <p class="text-muted mb-4">
                                <%= device.description || 'Dispositivo cadastrado' %>
                            </p>

                            <div class="mb-3">
                                <div class="d-flex justify-content-between mb-2">
                                    <span class="text-muted">Bateria</span>
                                    <span class="fw-semibold"><%= device.battery %>%</span>
                                </div>
                                <div class="battery-bar" style="background-color: #e9ecef; height: 8px; border-radius: 4px; overflow: hidden;">
                                    <div
                                        class="battery-level <%= device.battery > 20 ? 'bg-success' : 'bg-danger' %>"
                                        style="width: <%= device.battery %>%; height: 100%;"
                                    ></div>
                                </div>
                            </div>

                            <div class="mb-4">
                                <small class="text-muted">
                                    Última comunicação: 
                                    <%= device.last_communication || 'Nenhuma comunicação registrada' %>
                                </small>
                            </div>

                            <div class="d-flex gap-2">
                                <a href="/dashboard/events?device_id=<%= device.id %>" class="btn btn-primary flex-fill">
                                    <i class="bi bi-eye"></i> Detalhes
                                </a>
                                <a href="/dashboard/device/<%= device.id %>/edit" class="btn btn-outline-secondary">
                                    <i class="bi bi-gear"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

            <% }); %>
            <% } else { %>
                <div class="col-12 text-center py-5">
                    <i class="bi bi-cpu text-muted" style="font-size: 3rem;"></i>
                    <p class="text-muted mt-3">Nenhum dispositivo encontrado para este usuário.</p>
                </div>
            <% } %>

        </div>

    </main>

    <!-- Bootstrap -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js"></script>

    <script src="/socket.io/socket.io.js"></script>
    <script>
        const socket = io();
        // Injeta o ID direto do backend para o JS do front-end
        const currentUserId = "<%= user.id %>"; 

        socket.on('connect', () => {
            console.log('Socket conectado');
            
            if (currentUserId) {
                console.log('Enviando join-user para o id:', currentUserId);
                socket.emit('join-user', currentUserId);
            } else {
                console.error('Erro: currentUserId não foi encontrado no EJS');
            }
        });

        // Evento que escuta quando um dispositivo sofre uma queda
        socket.on('new-event', (event) => {
            console.log('Alerta de queda recebido via Socket:', event);
            
            // Como esta página é apenas a listagem de cards, você pode disparar um alerta visual
            // ou redirecionar o usuário caso ache necessário. Exemplo de alerta na tela:
            alert(`ATENÇÃO: Queda detectada no dispositivo ${event.device_id}!`);
        });

        // CORRIGIDO: Gerencia a alteração de status online/offline diretamente nos Cards
        socket.on('device-status-changed', (data) => {
            console.log('Status do dispositivo alterado:', data);

            // 1. Encontra o badge de status do dispositivo específico usando o data-device-id
            const statusBadge = document.querySelector(`[data-device-id="${data.deviceId}"]`);

            if (!statusBadge) {
                console.log(`Card do dispositivo ${data.deviceId} não encontrado nesta página.`);
                return;
            }

            // 2. Atualiza as classes do Bootstrap e o texto de acordo com o novo status
            if (data.status === 'online') {
                statusBadge.classList.remove('bg-danger');
                statusBadge.classList.add('bg-success');
                statusBadge.textContent = 'Online';
            } else {
                statusBadge.classList.remove('bg-success');
                statusBadge.classList.add('bg-danger');
                statusBadge.textContent = 'Offline';
            }
        });
    </script>
</body>
</html>