<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <title>Dashboard - Vigia Quedas</title>
    <%- include('../parts/head') %>
    <style>

        body {

            background: #f4f7fb;
        }

        /* Cards */

        .dashboard-card {

            border: none;
            border-radius: 20px;

            transition: 0.2s ease;
        }

        .dashboard-card:hover {

            transform: translateY(-5px);

            box-shadow:
                0 10px 25px rgba(0,0,0,0.08);
        }

        .card-icon {

            width: 60px;
            height: 60px;

            border-radius: 16px;

            display: flex;
            align-items: center;
            justify-content: center;

            font-size: 1.5rem;

            color: white;
        }

        .bg-blue {

            background: #0d6efd;
        }

        .bg-green {

            background: #198754;
        }

        .bg-red {

            background: #dc3545;
        }

        .bg-dark-custom {

            background: #212529;
        }

        /* Tabelas */

        .table-card {

            border: none;
            border-radius: 20px;
        }

        /* Status */

        .status-online {

            width: 10px;
            height: 10px;

            background: #198754;

            border-radius: 50%;

            display: inline-block;

            margin-right: 6px;
        }

        .status-offline {

            width: 10px;
            height: 10px;

            background: #dc3545;

            border-radius: 50%;

            display: inline-block;

            margin-right: 6px;
        }

    </style>

</head>
<body>

    <%- include('../parts/dash-template') %>

    <!-- Conteúdo -->
    <main class="main-content">
        <!-- Topbar -->
        <div class="topbar d-flex justify-content-between align-items-center flex-wrap gap-3">
            <div>
                <h2 class="fw-bold mb-1">
                    Dashboard
                </h2>

                <p class="text-muted mb-0">
                    Bem-vindo ao painel do Vigia Quedas
                </p>
            </div>

            <div class="text-end">
                <div class="fw-semibold">
                    Olá, <%= user.nome %>
                </div>

                <small class="text-muted">
                    Monitoramento em tempo real
                </small>
            </div>
        </div>

        <!-- Cards -->
        <div class="row g-4 mb-4">
            <div class="col-lg-3 col-md-6">
                <div class="card dashboard-card shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <p class="text-muted mb-2">
                                    Dispositivos
                                </p>

                                <h3 class="fw-bold">
                                    <%= devices.length || 0 %>
                                </h3>
                            </div>
                            <div class="card-icon bg-blue">
                                <i class="bi bi-cpu"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-3 col-md-6">
                <div class="card dashboard-card shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <p class="text-muted mb-2">Online</p>
                                <h3 class="fw-bold" id="onlineCounter"><%= devices.filter(d => d.status === 'online').length %></h3>
                            </div>
                            <div class="card-icon bg-green">
                                <i class="bi bi-wifi"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-3 col-md-6">
                <div class="card dashboard-card shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <p class="text-muted mb-2">Alertas</p>
                                <h3 class="fw-bold" id="fallCounter"><%= events.length || 0 %></h3>
                            </div>
                            <div class="card-icon bg-red">
                                <i class="bi bi-exclamation-triangle"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-3 col-md-6">
                <div class="card dashboard-card shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <p class="text-muted mb-2">Contatos</p>
                                <h3 class="fw-bold">0</h3>
                            </div>
                            <div class="card-icon bg-dark-custom">
                                <i class="bi bi-people"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tabelas -->
        <div class="row g-4">
            <!-- Meus Dispositivos -->
            <div class="col-12">
                <div class="card table-card shadow-sm">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
                            <div>
                                <h4 class="fw-bold mb-1">
                                    Meus Dispositivos
                                </h4>

                                <p class="text-muted mb-0">
                                    Dispositivos vinculados à sua conta
                                </p>
                            </div>

                            <button class="btn btn-primary">

                                <i class="bi bi-plus-lg"></i>
                                Novo Dispositivo

                            </button>
                        </div>

                        <div class="table-responsive">
                            <table class="table align-middle">
                                <thead>
                                    <tr>
                                        <th>
                                            Dispositivo
                                        </th>

                                        <th>
                                            Status
                                        </th>

                                        <th>
                                            Bateria
                                        </th>

                                        <th>
                                            Ações
                                        </th>
                                    </tr>
                                </thead>

                                <tbody>
                                    <% devices.forEach(device => { %>
                                    <tr>
                                        <td>
                                            <%= device.nome %>
                                        </td>

                                        <td class="device-status" data-device-id="<%= device.id %>">
                                            <span class="<%= device.status === 'online' ? 'status-online' : 'status-offline' %>"></span>
                                            <%= device.status %>
                                        </td>               

                                        <td>
                                            <%= device.battery_level %>
                                        </td>

                                        <td>
                                            <button class="btn btn-sm btn-outline-primary">
                                                Ver
                                            </button>
                                        </td>
                                    </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Pessoas Monitoradas -->
            <div class="col-lg-6">

                <div class="card table-card shadow-sm h-100">

                    <div class="card-body p-4">

                        <h4 class="fw-bold mb-1">
                            Pessoas Monitoradas
                        </h4>

                        <p class="text-muted mb-4">
                            Usuários que cadastraram você como contato de emergência
                        </p>

                        <div class="table-responsive">
                            <table class="table align-middle">
                                <thead>
                                    <tr>

                                        <th>
                                            Usuário
                                        </th>

                                        <th>
                                            Status
                                        </th>

                                        <th>
                                            -
                                        </th>
                                    </tr>
                                </thead>

                                <tbody>
                                    <% monitored_users.forEach(contact => { %>
                                        <tr>
                                            <td>
                                                <%= contact.nome %>
                                            </td>

                                            <td>
                                                <% 
                                                    // Verifica se o usuário tem dispositivos E se pelo menos um deles está online
                                                    const temDispositivoOnline = contact.devices && contact.devices.some(device => device.status === 'online'); 
                                                %>
                                                
                                                <% if (temDispositivoOnline) { %>
                                                    <span class="badge bg-success">
                                                        <i class="bi bi-circle-fill me-1" style="font-size: 0.5rem;"></i> Online
                                                    </span>
                                                <% } else if (contact.devices && contact.devices.length > 0) { %>
                                                    <span class="badge bg-secondary">
                                                        Offline
                                                    </span>
                                                <% } else { %>
                                                    <span class="badge bg-light text-muted border">
                                                        Sem Dispositivos
                                                    </span>
                                                <% } %>
                                            </td>

                                            <td>
                                                <span class="badge <%= contact.status === 'active' ? 'bg-primary' : 'bg-warning text-dark' %>">
                                                    <%= contact.status === 'active' ? 'Ativo' : 'Pendente' %>
                                                </span>
                                            </td>
                                        </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        </div>

                    </div>

                </div>

            </div>

            <!-- Meus Contatos -->
            <div class="col-lg-6">

                <div class="card table-card shadow-sm h-100">

                    <div class="card-body p-4">

                        <h4 class="fw-bold mb-1">
                            Meus Contatos de Emergência
                        </h4>

                        <p class="text-muted mb-4">
                            Pessoas que receberão alertas caso uma queda seja detectada
                        </p>

                        <div class="table-responsive">
                            <table class="table align-middle">
                                <thead>
                                    <tr>
                                        <th>
                                            Nome
                                        </th>
                                        <th>
                                            Relação
                                        </th>
                                        <th>
                                            Status
                                        </th>
                                    </tr>
                                </thead>

                                <tbody>
                                    <% emergency_contacts.forEach(contact => { %>
                                        <tr>
                                            <td>
                                                <%= contact.nome %>
                                            </td>

                                            <td>
                                                <%= contact.relacao || 'Não informada' %>
                                            </td>

                                            <td>
                                                <%= contact.status === 'active' ? 'Ativo' : 'Pendente' %>
                                            </td>
                                        </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        </div>

                    </div>

                </div>

            </div>

        </div>

    </main>

    <%- include('../parts/dash-foot') %>

    <!-- Bootstrap -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js"></script>

    <script src="/socket.io/socket.io.js"></script>
    <script>
        const socket = io();
        // Injeta o ID direto do backend para o JS do front-end
        const currentUserId = "<%= user.id %>"; // Ajuste para a sua variável do EJS (ex: user._id, userId, etc.)

        socket.on('connect', () => {
            console.log('Socket conectado');
            
            if (currentUserId) {
                console.log('Enviando join-user para o id:', currentUserId);
                socket.emit('join-user', currentUserId);
            } else {
                console.error('Erro: currentUserId não foi encontrado no EJS');
            }
        });

        socket.on('new-event', (event) => {
            console.log(event);

            const timeline = document.getElementById('eventsTimeline');
            const counter = document.getElementById('fallCounter');

            counter.textContent = Number(counter.textContent) + 1;

            // const html = `
            //     <div class="timeline-item">

            //         <div class="timeline-dot bg-danger"></div>

            //         <div class="timeline-content">

            //             <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-3">

            //                 <div>

            //                     <h5 class="fw-bold text-danger mb-1">
            //                         Queda Detectada
            //                     </h5>

            //                     <p class="text-muted mb-0">
            //                         Dispositivo ${event.device_id}
            //                     </p>

            //                 </div>

            //                 <span class="badge bg-danger">
            //                     Crítico
            //                 </span>

            //             </div>

            //             <p class="mb-3">
            //                 ${event.descricao}
            //             </p>

            //         </div>

            //     </div>
            // `;

            // timeline.insertAdjacentHTML(
            //     'afterbegin',
            //     html
            // );
        });

        // socket.on('device-status-changed', (data) => {

        //     const cell = document.querySelector(
        //         `[data-device-id="${data.deviceId}"]`
        //     );

        //     if (!cell) {
        //         return;
        //     }

        //     const statusClass = data.status === 'online' ? 'status-online' : 'status-offline';

        //     cell.innerHTML = `
        //         <span class="${statusClass}"></span>
        //         ${data.status}
        //     `;
        // });

        // ATUALIZADO: Gerencia a alteração de status e recalcula o card do topo
        socket.on('device-status-changed', (data) => {

            // 1. Encontra a célula do dispositivo alvo
            const cell = document.querySelector(`[data-device-id="${data.deviceId}"]`);

            if (!cell) {
                return;
            }

            // 2. Atualiza visualmente o status dele na tabela externa
            const statusClass = data.status === 'online' ? 'status-online' : 'status-offline';

            cell.innerHTML = `
                <span class="${statusClass}"></span>
                ${data.status}
            `;

            // 3. Recala a contagem total de dispositivos online na tela
            const onlineCounter = document.getElementById('onlineCounter');
            if (onlineCounter) {
                // Busca todas as células de status da tabela de dispositivos
                const allStatusCells = document.querySelectorAll('.device-status');
                let totalOnline = 0;

                // Conta quantas células contém a palavra 'online' após a alteração
                allStatusCells.forEach(c => {
                    if (c.textContent.trim().toLowerCase() === 'online') {
                        totalOnline++;
                    }
                });

                // Altera o número no card superior do topo
                onlineCounter.textContent = totalOnline;
            }
        });
        
    </script>
    <script src="/js/toast-notification.js" defer></script>

</body>
</html>