<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <title>Dashboard - Vigia Quedas</title>
    <%- include('../parts/head') %>
    <style>

        body {

            background: #f4f7fb;
        }

        /* Cards */

        .dashboard-card {

            border: none;
            border-radius: 20px;

            transition: 0.2s ease;
        }

        .dashboard-card:hover {

            transform: translateY(-5px);

            box-shadow:
                0 10px 25px rgba(0,0,0,0.08);
        }

        .card-icon {

            width: 60px;
            height: 60px;

            border-radius: 16px;

            display: flex;
            align-items: center;
            justify-content: center;

            font-size: 1.5rem;

            color: white;
        }

        .bg-blue {

            background: #0d6efd;
        }

        .bg-green {

            background: #198754;
        }

        .bg-red {

            background: #dc3545;
        }

        .bg-dark-custom {

            background: #212529;
        }

        /* Tabelas */

        .table-card {

            border: none;
            border-radius: 20px;
        }

        /* Status */

        .status-online {

            width: 10px;
            height: 10px;

            background: #198754;

            border-radius: 50%;

            display: inline-block;

            margin-right: 6px;
        }

        .status-offline {

            width: 10px;
            height: 10px;

            background: #dc3545;

            border-radius: 50%;

            display: inline-block;

            margin-right: 6px;
        }

    </style>

</head>
<body>

    <%- include('../parts/dash-template') %>

    <!-- Conteúdo -->
    <main class="main-content">

        <!-- Topbar -->
        <div class="topbar d-flex justify-content-between align-items-center flex-wrap gap-3">

            <div>

                <h2 class="fw-bold mb-1">
                    Dashboard
                </h2>

                <p class="text-muted mb-0">
                    Bem-vindo ao painel do Vigia Quedas
                </p>

            </div>

            <div class="text-end">

                <div class="fw-semibold">
                    Olá, Usuário
                </div>

                <small class="text-muted">
                    Monitoramento em tempo real
                </small>

            </div>

        </div>

        <!-- Cards -->
        <div class="row g-4 mb-4">

            <div class="col-lg-3 col-md-6">

                <div class="card dashboard-card shadow-sm">

                    <div class="card-body">

                        <div class="d-flex justify-content-between align-items-center">

                            <div>

                                <p class="text-muted mb-2">
                                    Dispositivos
                                </p>

                                <h3 class="fw-bold">
                                    12
                                </h3>

                            </div>

                            <div class="card-icon bg-blue">
                                <i class="bi bi-cpu"></i>
                            </div>

                        </div>

                    </div>

                </div>

            </div>

            <div class="col-lg-3 col-md-6">

                <div class="card dashboard-card shadow-sm">

                    <div class="card-body">

                        <div class="d-flex justify-content-between align-items-center">

                            <div>

                                <p class="text-muted mb-2">
                                    Online
                                </p>

                                <h3 class="fw-bold">
                                    10
                                </h3>

                            </div>

                            <div class="card-icon bg-green">
                                <i class="bi bi-wifi"></i>
                            </div>

                        </div>

                    </div>

                </div>

            </div>

            <div class="col-lg-3 col-md-6">

                <div class="card dashboard-card shadow-sm">

                    <div class="card-body">

                        <div class="d-flex justify-content-between align-items-center">

                            <div>

                                <p class="text-muted mb-2">
                                    Alertas
                                </p>

                                <h3 class="fw-bold">
                                    3
                                </h3>

                            </div>

                            <div class="card-icon bg-red">
                                <i class="bi bi-exclamation-triangle"></i>
                            </div>

                        </div>

                    </div>

                </div>

            </div>

            <div class="col-lg-3 col-md-6">

                <div class="card dashboard-card shadow-sm">

                    <div class="card-body">

                        <div class="d-flex justify-content-between align-items-center">

                            <div>

                                <p class="text-muted mb-2">
                                    Contatos
                                </p>

                                <h3 class="fw-bold">
                                    7
                                </h3>

                            </div>

                            <div class="card-icon bg-dark-custom">
                                <i class="bi bi-people"></i>
                            </div>

                        </div>

                    </div>

                </div>

            </div>

        </div>

        <!-- Tabelas -->
        <div class="row g-4">

            <!-- Meus Dispositivos -->
            <div class="col-12">

                <div class="card table-card shadow-sm">

                    <div class="card-body p-4">

                        <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">

                            <div>

                                <h4 class="fw-bold mb-1">
                                    Meus Dispositivos
                                </h4>

                                <p class="text-muted mb-0">
                                    Dispositivos vinculados à sua conta
                                </p>

                            </div>

                            <button class="btn btn-primary">

                                <i class="bi bi-plus-lg"></i>
                                Novo Dispositivo

                            </button>

                        </div>

                        <div class="table-responsive">

                            <table class="table align-middle">

                                <thead>

                                    <tr>

                                        <th>
                                            Dispositivo
                                        </th>

                                        <th>
                                            Status
                                        </th>

                                        <th>
                                            Última Comunicação
                                        </th>

                                        <th>
                                            Bateria
                                        </th>

                                        <th>
                                            Ações
                                        </th>

                                    </tr>

                                </thead>

                                <tbody>

                                    <tr>

                                        <td>
                                            ESP32-001
                                        </td>

                                        <td>
                                            <span class="status-online"></span>
                                            Online
                                        </td>

                                        <td>
                                            Agora mesmo
                                        </td>

                                        <td>
                                            87%
                                        </td>

                                        <td>

                                            <button class="btn btn-sm btn-outline-primary">
                                                Ver
                                            </button>

                                        </td>

                                    </tr>

                                    <tr>

                                        <td>
                                            ESP32-002
                                        </td>

                                        <td>
                                            <span class="status-offline"></span>
                                            Offline
                                        </td>

                                        <td>
                                            Há 35 minutos
                                        </td>

                                        <td>
                                            15%
                                        </td>

                                        <td>

                                            <button class="btn btn-sm btn-outline-primary">
                                                Ver
                                            </button>

                                        </td>

                                    </tr>

                                </tbody>

                            </table>

                        </div>

                    </div>

                </div>

            </div>

            <!-- Pessoas Monitoradas -->
            <div class="col-lg-6">

                <div class="card table-card shadow-sm h-100">

                    <div class="card-body p-4">

                        <h4 class="fw-bold mb-1">
                            Pessoas Monitoradas
                        </h4>

                        <p class="text-muted mb-4">
                            Usuários que cadastraram você como contato de emergência
                        </p>

                        <div class="table-responsive">

                            <table class="table align-middle">

                                <thead>

                                    <tr>

                                        <th>
                                            Usuário
                                        </th>

                                        <th>
                                            Status
                                        </th>

                                        <th>
                                            Último Evento
                                        </th>

                                    </tr>

                                </thead>

                                <tbody>

                                    <tr>

                                        <td>
                                            Maria Silva
                                        </td>

                                        <td>
                                            <span class="status-online"></span>
                                            Seguro
                                        </td>

                                        <td>
                                            Sem alertas
                                        </td>

                                    </tr>

                                    <tr>

                                        <td>
                                            João Souza
                                        </td>

                                        <td>
                                            <span class="status-online"></span>
                                            Monitorando
                                        </td>

                                        <td>
                                            Movimento detectado
                                        </td>

                                    </tr>

                                    <tr>

                                        <td>
                                            Ana Costa
                                        </td>

                                        <td>
                                            <span class="status-offline"></span>
                                            Dispositivo Offline
                                        </td>

                                        <td>
                                            Há 1 hora
                                        </td>

                                    </tr>

                                </tbody>

                            </table>

                        </div>

                    </div>

                </div>

            </div>

            <!-- Meus Contatos -->
            <div class="col-lg-6">

                <div class="card table-card shadow-sm h-100">

                    <div class="card-body p-4">

                        <h4 class="fw-bold mb-1">
                            Meus Contatos de Emergência
                        </h4>

                        <p class="text-muted mb-4">
                            Pessoas que receberão alertas caso uma queda seja detectada
                        </p>

                        <div class="table-responsive">

                            <table class="table align-middle">

                                <thead>

                                    <tr>

                                        <th>
                                            Nome
                                        </th>

                                        <th>
                                            Relação
                                        </th>

                                        <th>
                                            Status
                                        </th>

                                    </tr>

                                </thead>

                                <tbody>

                                    <tr>

                                        <td>
                                            Carlos Mendes
                                        </td>

                                        <td>
                                            Filho
                                        </td>

                                        <td>
                                            Ativo
                                        </td>

                                    </tr>

                                    <tr>

                                        <td>
                                            Fernanda Lima
                                        </td>

                                        <td>
                                            Cuidadora
                                        </td>

                                        <td>
                                            Ativo
                                        </td>

                                    </tr>

                                    <tr>

                                        <td>
                                            Roberto Alves
                                        </td>

                                        <td>
                                            Vizinho
                                        </td>

                                        <td>
                                            Pendente
                                        </td>

                                    </tr>

                                </tbody>

                            </table>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </main>

    <!-- Bootstrap -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>