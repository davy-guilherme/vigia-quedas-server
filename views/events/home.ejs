            <div class="modal fade" id="filterModal" tabindex="-1" aria-labelledby="filterModalLabel" aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content" style="border-radius: 20px;">
                        <div class="modal-header border-0 pb-0">
                            <h5 class="modal-title fw-bold" id="filterModalLabel">Filtrar Histórico</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <form id="filterForm" action="/dashboard/events" method="GET"> 
                            <div class="modal-body py-4">
                                
                                <div class="mb-3">
                                    <label class="form-label text-muted fw-semibold small">Dispositivo</label>
                                    <select class="form-select border-0 bg-light p-3" name="device_id" style="border-radius: 12px;">
                                        <option value="">Todos os Dispositivos</option>
                                        <% if (typeof devices !== 'undefined' && devices.length > 0) { %>
                                            <% devices.forEach(dev => { %>
                                                <option value="<%= dev.id %>" <%= typeof filters !== 'undefined' && filters.device_id == dev.id ? 'selected' : '' %>>
                                                    <%= dev.nome %> (<%= dev.serial_number %>) - [<%= String(dev.user_id) === String(user.id) ? 'Meu Dispositivo' : 'Monitorado: ' + (dev.dono_nome || 'Usuário') %>]
                                                </option>
                                            <% }); %>
                                        <% } %>
                                    </select>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label text-muted fw-semibold small">Tipo de Alerta</label>
                                    <select class="form-select border-0 bg-light p-3" name="tipo" style="border-radius: 12px;">
                                        <option value="">Todos os Tipos</option>
                                        <option value="fall_detected" <%= typeof filters !== 'undefined' && filters.tipo === 'fall_detected' ? 'selected' : '' %>>Queda Detectada (Offline)</option>
                                        <option value="fall_confirmed" <%= typeof filters !== 'undefined' && filters.tipo === 'fall_confirmed' ? 'selected' : '' %>>Queda Confirmada (Tempo Real)</option>
                                        <option value="device_offline" <%= typeof filters !== 'undefined' && filters.tipo === 'device_offline' ? 'selected' : '' %>>Dispositivo Offline</option>
                                        <option value="low_battery" <%= typeof filters !== 'undefined' && filters.tipo === 'low_battery' ? 'selected' : '' %>>Bateria Baixa</option>
                                    </select>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label text-muted fw-semibold small">Status do Alerta</label>
                                    <select class="form-select border-0 bg-light p-3" name="status" style="border-radius: 12px;">
                                        <option value="">Todos os Status</option>
                                        <option value="pending" <%= typeof filters !== 'undefined' && filters.status === 'pending' ? 'selected' : '' %>>Pendente</option>
                                        <option value="notified" <%= typeof filters !== 'undefined' && filters.status === 'notified' ? 'selected' : '' %>>Notificado</option>
                                        <option value="resolved" <%= typeof filters !== 'undefined' && filters.status === 'resolved' ? 'selected' : '' %>>Resolvido</option>
                                    </select>
                                </div>
                            </div>
                            <div class="modal-footer border-0 pt-0 gap-2">
                                <a href="/dashboard/events" class="btn btn-light flex-fill p-2" style="border-radius: 12px;">Limpar</a>
                                <button type="submit" class="btn btn-primary flex-fill p-2" style="border-radius: 12px;">Aplicar Filtros</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
            <!-- fim filtragem de alertas -->   

        </div>

        <!-- Cards Resumo -->
        <div class="row g-4 mb-4">
            <div class="col-lg-3 col-md-6">
                <div class="card alert-card shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <p class="text-muted mb-2">
                                    Quedas Detectadas
                                </p>

                                <h3 class="fw-bold" id="fallCounter">
                                    <%= events.length || 0 %>
                                </h3>
                            </div>
                            <div class="alert-icon alert-danger-custom">
                                <i class="bi bi-exclamation-triangle"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-3 col-md-6">
                <div class="card alert-card shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <p class="text-muted mb-2">
                                    Bateria Baixa
                                </p>

                                <h3 class="fw-bold">
                                    0
                                </h3>
                            </div>
                            <div class="alert-icon alert-warning-custom">
                                <i class="bi bi-battery-half"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        
            <div class="col-lg-3 col-md-6">
                <div class="card alert-card shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <p class="text-muted mb-2">
                                    Dispositivos Offline
                                </p>

                                <h3 class="fw-bold">
                                    0
                                </h3>
                            </div>
                            <div class="alert-icon bg-secondary">
                                <i class="bi bi-wifi-off"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-3 col-md-6">
                <div class="card alert-card shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <p class="text-muted mb-2">
                                    Alertas Resolvidos
                                </p>

                                <h3 class="fw-bold">
                                    0
                                </h3>
                            </div>
                            <div class="alert-icon alert-success-custom">
                                <i class="bi bi-check-circle"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>

        <!-- Timeline -->
        <div class="timeline" id="eventsTimeline">
            <!-- Evento -->
            <% events.forEach(event => { %>
                <div class="timeline-item">
                    <div class="timeline-dot bg-danger"></div>
                    <div class="timeline-content">
                        <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-3">
                            <div>
                                <h5 class="fw-bold text-danger mb-1"><%= event.tipo %></h5>
                                <p class="text-muted mb-0"><%= event.user_id === user.id ? 'Meu Perfil' : event.usuario_nome %> - <%= event.device_id%></p>
                            </div>

                            <span class="badge bg-danger">
                                Crítico
                            </span>
                        </div>

                        <p class="mb-3">
                            Uma possível queda foi detectada pelo dispositivo.
                        </p>

                        <div class="d-flex flex-wrap gap-2">
                            <button class="btn btn-sm btn-primary">
                                <i class="bi bi-eye"></i> Ver Detalhes
                            </button>

                            <button class="btn btn-sm btn-outline-success">
                                <i class="bi bi-check2"></i> Marcar Resolvido
                            </button>
                        </div>
                        <small class="text-muted d-block mt-3"><%= event.created_at %></small>
                    </div>
                </div>
                <% }) %>
        </div>




        <!-- Timeline antiga -->
        <div class="timeline">

            <!-- Evento -->
            <div class="timeline-item">

                <div class="timeline-dot bg-warning"></div>

                <div class="timeline-content">

                    <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-3">

                        <div>

                            <h5 class="fw-bold text-warning mb-1">

                                Bateria Baixa

                            </h5>

                            <p class="text-muted mb-0">

                                João Souza - ESP32-002

                            </p>

                        </div>

                        <span class="badge bg-warning text-dark">
                            Atenção
                        </span>

                    </div>

                    <p class="mb-3">

                        O dispositivo está com nível crítico de bateria
                        e pode deixar de enviar dados em breve.

                    </p>

                    <small class="text-muted">

                        Hoje às 11:15

                    </small>

                </div>

            </div>

            <!-- Evento -->
            <div class="timeline-item">

                <div class="timeline-dot bg-secondary"></div>

                <div class="timeline-content">

                    <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-3">

                        <div>

                            <h5 class="fw-bold text-secondary mb-1">

                                Dispositivo Offline

                            </h5>

                            <p class="text-muted mb-0">

                                Ana Costa - ESP32-003

                            </p>

                        </div>

                        <span class="badge bg-secondary">
                            Offline
                        </span>

                    </div>

                    <p class="mb-3">

                        O dispositivo perdeu conexão com o servidor
                        há mais de 1 hora.

                    </p>

                    <small class="text-muted">

                        Ontem às 21:48

                    </small>

                </div>

            </div>

            <!-- Evento -->
            <div class="timeline-item">

                <div class="timeline-dot bg-success"></div>

                <div class="timeline-content">

                    <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-3">

                        <div>

                            <h5 class="fw-bold text-success mb-1">

                                Alerta Resolvido

                            </h5>

                            <p class="text-muted mb-0">

                                Carlos Mendes - ESP32-004

                            </p>

                        </div>

                        <span class="badge bg-success">
                            Resolvido
                        </span>

                    </div>

                    <p class="mb-3">

                        O alerta foi confirmado e encerrado pelo contato responsável.

                    </p>

                    <small class="text-muted">

                        Ontem às 18:10

                    </small>

                </div>

            </div>

        </div>

    </main>

    <%- include('../parts/dash-foot') %>

    <!-- Bootstrap -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js"></script>

    <script src="/socket.io/socket.io.js"></script>
    <script>
        const socket = io();
        // Injeta o ID direto do backend para o JS do front-end
        const currentUserId = "<%= user.id %>"; // Ajuste para a sua variável do EJS (ex: user._id, userId, etc.)

        socket.on('connect', () => {
            console.log('Socket conectado');
            
            if (currentUserId) {
                console.log('Enviando join-user para o id:', currentUserId);
                socket.emit('join-user', currentUserId);
            } else {
                console.error('Erro: currentUserId não foi encontrado no EJS');
            }
        });

        socket.on('new-event', (event) => {
            console.log(event);

            const timeline = document.getElementById('eventsTimeline');
            const counter = document.getElementById('fallCounter');

            counter.textContent = Number(counter.textContent) + 1;

            const html = `
                <div class="timeline-item">

                    <div class="timeline-dot bg-danger"></div>

                    <div class="timeline-content">

                        <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-3">

                            <div>

                                <h5 class="fw-bold text-danger mb-1">
                                    Queda Detectada
                                </h5>

                                <p class="text-muted mb-0">
                                    Dispositivo ${event.device_id}
                                </p>

                            </div>

                            <span class="badge bg-danger">
                                Crítico
                            </span>

                        </div>

                        <p class="mb-3">
                            ${event.descricao}
                        </p>

                    </div>

                </div>
            `;

            timeline.insertAdjacentHTML(
                'afterbegin',
                html
            );
        });
    </script>
    <script src="/js/toast-notification.js" defer></script>
</body>
</html>