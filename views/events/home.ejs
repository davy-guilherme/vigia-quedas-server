<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <title>Alertas - Vigia Quedas</title>
    <%- include('../parts/head') %>
    <style>

        body {

            background: #f4f7fb;
        }

        /* Sidebar */

        .sidebar {

            width: 280px;
            min-height: 100vh;

            background:
                linear-gradient(
                    180deg,
                    #0d6efd,
                    #0a58ca
                );

            position: fixed;
            top: 0;
            left: 0;

            padding: 25px;

            color: white;
        }

        .sidebar-brand {

            font-size: 1.5rem;
            font-weight: 700;

            margin-bottom: 40px;
        }

        .sidebar-link {

            display: flex;
            align-items: center;
            gap: 12px;

            padding: 14px 16px;

            border-radius: 14px;

            color: rgba(255,255,255,0.9);
            text-decoration: none;

            margin-bottom: 10px;

            transition: 0.2s;
        }

        .sidebar-link:hover,
        .sidebar-link.active {

            background: rgba(255,255,255,0.15);

            color: white;
        }

        /* Main */

        .main-content {

            margin-left: 280px;
            padding: 30px;
        }

        /* Topbar */

        .topbar {

            background: white;

            border-radius: 20px;

            padding: 20px 25px;

            margin-bottom: 30px;

            box-shadow:
                0 5px 20px rgba(0,0,0,0.04);
        }

        /* Alert Cards */

        .alert-card {

            border: none;
            border-radius: 24px;

            transition: 0.2s ease;
        }

        .alert-card:hover {

            transform: translateY(-4px);

            box-shadow:
                0 10px 30px rgba(0,0,0,0.08);
        }

        .alert-icon {

            width: 65px;
            height: 65px;

            border-radius: 18px;

            display: flex;
            align-items: center;
            justify-content: center;

            font-size: 1.8rem;

            color: white;
        }

        .alert-danger-custom {

            background: #dc3545;
        }

        .alert-warning-custom {

            background: #ffc107;
            color: #212529;
        }

        .alert-info-custom {

            background: #0dcaf0;
        }

        .alert-success-custom {

            background: #198754;
        }

        .timeline {

            position: relative;
            padding-left: 25px;
        }

        .timeline::before {

            content: "";

            position: absolute;
            left: 7px;
            top: 0;
            bottom: 0;

            width: 2px;

            background: #dee2e6;
        }

        .timeline-item {

            position: relative;
            margin-bottom: 30px;
        }

        .timeline-dot {

            position: absolute;

            left: -25px;
            top: 8px;

            width: 16px;
            height: 16px;

            border-radius: 50%;

            background: #0d6efd;
        }

        .timeline-content {

            background: white;

            border-radius: 18px;

            padding: 20px;

            box-shadow:
                0 5px 20px rgba(0,0,0,0.04);
        }

        

    </style>

</head>
<body>

    <%- include('../parts/dash-template') %>

    <!-- Conteúdo -->
    <main class="main-content">

        <!-- Topbar -->
        <div class="topbar d-flex justify-content-between align-items-center flex-wrap gap-3">

            <div>

                <h2 class="fw-bold mb-1">
                    Alertas
                </h2>

                <p class="text-muted mb-0">
