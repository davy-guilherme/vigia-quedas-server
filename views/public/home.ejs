<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <title>Vigia Quedas</title>
    <%- include('../parts/head') %>
    <style>

    body {
        background-color: #f8f9fa;
    }

    .hero {
        background: linear-gradient(135deg, #0d6efd, #0a58ca);
        color: white;
        padding: 120px 0;
    }

    .hero h1 {
        font-size: 3rem;
        font-weight: 700;
    }

    .feature-icon {
        font-size: 3rem;
        color: #0d6efd;
    }

    .feature-card {
        transition: 0.2s ease;
        border: none;
        border-radius: 16px;
    }

    .feature-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 25px rgba(0,0,0,0.08);
    }

    .status-box {
        border-radius: 18px;
        overflow: hidden;
    }

    footer {
        background-color: #212529;
        color: #adb5bd;
    }

    </style>
</head>
<body>
    <%- include('../parts/navbar') %>
    <!-- Hero -->
    <section class="hero">
        <div class="container">
            <div class="row align-items-center g-5">
                <div class="col-lg-6">
                    <h1>Monitoramento inteligente de quedas em tempo real</h1>
                    <p class="lead mt-4">
                        O Vigia Quedas ajuda a proteger pessoas em situação de risco
                        através de dispositivos inteligentes capazes de detectar quedas
                        e enviar alertas automáticos para contatos de emergência.
                    </p>

                    <div class="mt-4 d-flex gap-3 flex-wrap">
                        <a href="/auth/register" class="btn btn-light btn-lg">
                            Crie sua conta
                        </a>

                        <a href="/about" class="btn btn-outline-light btn-lg">
                            Saiba Mais
                        </a>
                    </div>
                </div>

                <div class="col-lg-6 text-center">
                    <!-- 
                    <img
                        src="https://images.unsplash.com/photo-1516574187841-cb9cc2ca948b?q=80&w=1200&auto=format&fit=crop"
                        class="img-fluid rounded-4 shadow-lg"
                        alt="Monitoramento de saúde"
                    >
                    -->
                    <img
                        src="img/vigia-quedas.png"
                        class="img-fluid rounded-4 shadow-lg"
                        alt="Monitoramento de saúde"
                    >
                </div>
            </div>
        </div>
    </section>

    <!-- Recursos -->
    <section class="py-5" id="recursos">
        <div class="container">
            <div class="text-center mb-5">
                <h2 class="fw-bold">Principais Recursos</h2>
                <p class="text-muted">
                    Segurança, monitoramento e comunicação em um único sistema.
                </p>
            </div>

            <div class="row g-4">

                <div class="col-md-4">
                    <div class="card feature-card h-100 shadow-sm">
                        <div class="card-body text-center p-4">
                            <div class="feature-icon mb-3">
                                <i class="bi bi-exclamation-triangle"></i>
                            </div>
                            <h4> Detecção de Quedas</h4>
                            <p class="text-muted">
                                Sensores inteligentes identificam possíveis quedas
                                automaticamente em poucos segundos.
                            </p>
                        </div>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="card feature-card h-100 shadow-sm">
                        <div class="card-body text-center p-4">
                            <div class="feature-icon mb-3">
                                <i class="bi bi-bell"></i>
                            </div>
                            <h4>Alertas Instantâneos</h4>
                            <p class="text-muted">
                                Envio automático de notificações para familiares,
                                cuidadores e contatos de emergência.
                            </p>
                        </div>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="card feature-card h-100 shadow-sm">
                        <div class="card-body text-center p-4">
                            <div class="feature-icon mb-3">
                                <i class="bi bi-phone"></i>
                            </div>
                            <h4>Painel Online</h4>
                            <p class="text-muted">
                                Acompanhe dispositivos, eventos e usuários através
                                de um painel simples e responsivo.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Status -->
    <section class="py-5">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-4">
                    <div class="bg-primary text-white p-5 status-box shadow">
                        <h2 class="fw-bold">
                            24h
                        </h2>

                        <p class="mb-0">
                            Monitoramento contínuo dos dispositivos cadastrados.
                        </p>
                    </div>
                </div>

                <div class="col-lg-4">
                    <div class="bg-success text-white p-5 status-box shadow">
                        <h2 class="fw-bold">
                            MQTT
                        </h2>
                        <p class="mb-0">
                            Comunicação rápida e eficiente entre dispositivos e servidor.
                        </p>
                    </div>
                </div>

                <div class="col-lg-4">
                    <div class="bg-dark text-white p-5 status-box shadow">
                        <h2 class="fw-bold">
                            Tempo Real
                        </h2>
                        <p class="mb-0">
                            Eventos e notificações atualizados instantaneamente.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Call To Action -->
    <section class="py-5 bg-light">
        <div class="container text-center">
            <h2 class="fw-bold">
                Pronto para começar?
            </h2>
            <p class="text-muted mt-3 mb-4">
                Cadastre seus dispositivos e mantenha seus contatos de emergência sempre informados.
            </p>
            <div class="d-flex justify-content-center gap-3 flex-wrap">
                <a href="/auth/register" class="btn btn-primary btn-lg px-5">
                    Crie sua conta
                </a>

                <a href="/auth/login" class="btn btn-outline-primary btn-lg px-5">
                    Acesse o Painel
                </a>
            </div>
        </div>
    </section>

    <%-include('../parts/foot') %>
</body>
</html>