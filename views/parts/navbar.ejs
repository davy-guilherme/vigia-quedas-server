<style>
    /* Removemos a margem esquerda do Desktop, já que a barra não é mais fixa */
    .main-content {
        padding: 30px;
        transition: all 0.3s ease;
    }

    .sidebar-link {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 14px 16px;
        border-radius: 14px;
        color: rgba(255, 255, 255, 0.8);
        text-decoration: none;
        margin-bottom: 10px;
        transition: 0.2s;
    }

    .sidebar-link:hover,
    .sidebar-link.active {
        background: rgba(255, 255, 255, 0.1);
        color: white;
    }

    /* Responsivo - Mantém o espaçamento correto em telas menores */
    @media(max-width: 991px) {
        .main-content {
            padding: 20px;
        }
    }
</style>

<nav class="navbar navbar-dark bg-dark shadow-sm sticky-top">
    <div class="container-fluid px-4">
        <a class="navbar-brand fw-bold" href="/">
            <i class="bi bi-shield-check"></i>
            Vigia Quedas
        </a>

        <button
            class="navbar-toggler border-0"
            type="button"
            data-bs-toggle="offcanvas"
            data-bs-target="#landingUnifiedMenu"
        >
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</nav>

<div
    class="offcanvas offcanvas-start text-bg-dark"
    tabindex="-1"
    id="landingUnifiedMenu"
    style="width: 280px;" 
>
    <div class="offcanvas-header px-4 pt-4">
        <h5 class="offcanvas-title fw-bold">
            <i class="bi bi-shield-check"></i>
            Vigia Quedas
        </h5>
        <button
            type="button"
            class="btn-close btn-close-white"
            data-bs-dismiss="offcanvas"
        ></button>
    </div>

    <div class="offcanvas-body d-flex flex-column justify-content-between px-4 pb-4">
        <nav class="mt-3">
            <a href="/" class="sidebar-link <%= currentUrl === '/' ? 'active' : '' %>">
                <i class="bi bi-house"></i>
                Início
            </a>

            <a href="/about" class="sidebar-link <%= currentUrl === '/about' ? 'active' : '' %>">
                <i class="bi bi-star"></i>
                Sobre
            </a>
        </nav>

        <div class="d-grid gap-2 mt-5">
            <a class="btn btn-outline-light w-100" href="/auth/register" style="border-radius: 10px;">
                Criar Conta
            </a>
            <a class="btn btn-primary w-100" href="/auth/login" style="border-radius: 10px;">
                Acessar Painel
            </a>
        </div>
    </div>
</div>