<!-- Navbar Mobile -->
<style>
    /* Sidebar Desktop */

    .sidebar {

        width: 280px;
        min-height: 100vh;

        background:
            linear-gradient(
                180deg,
                #0d6efd,
                #0a58ca
            );

        position: fixed;
        top: 0;
        left: 0;

        padding: 25px;

        color: white;
    }

    .sidebar-brand {

        font-size: 1.5rem;
        font-weight: 700;

        margin-bottom: 40px;
    }

    .sidebar-link {

        display: flex;
        align-items: center;
        gap: 12px;

        padding: 14px 16px;

        border-radius: 14px;

        color: rgba(255,255,255,0.9);
        text-decoration: none;

        margin-bottom: 10px;

        transition: 0.2s;
    }

    .sidebar-link:hover,
    .sidebar-link.active {

        background: rgba(255,255,255,0.15);

        color: white;
    }

    /* Conteúdo */

    .main-content {

        margin-left: 280px;
        padding: 30px;
    }

    /* Topbar */

    .topbar {

        background: white;

        border-radius: 20px;

        padding: 20px 25px;

        margin-bottom: 30px;

        box-shadow:
            0 5px 20px rgba(0,0,0,0.04);
    }

    /* Responsivo */

    @media(max-width: 991px) {

        .main-content {

            margin-left: 0;
            padding: 20px;
        }

    }
    
</style>

